# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool, specifically when used with LiteIDE
*.out

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work

# macOS
.DS_Store

# IDEs
*.code-workspace
.vscode/
.idea/

# Legacy paths
go_rds/logs
backend/logs
go_rds/cmd/__debug_bin
go_rds_windows.code-workspace

go_rds/dist/
go_rds/go_rds/dist
go_rds/bin/
go_rds.code-workspace
github.go_rds.code-workspace

# Project specific
# Backend
backend/logs/
backend/media/
backend/web/dist/*
!backend/web/dist/
!backend/web/dist/index.html
backend/code.code-workspace

# Frontend
www/dist/
www/node_modules/
www/.vite/
www/.vscode

# Build artifacts
bin/
*.tar.gz
*.zip
*.sha256
www/README.md
logs/
media/
.worktrees/
