[client]
# CLIENT #
port                                                          = 123
socket                                                        = /run/mysql.sock

[mysqld]
# GENERAL #
port                                                          = 123
mysqlx_port                                                   = 1230
admin_port                                                    = 1232
server_id                                                     = 0
user                                                          = mysql
socket                                                        = /run/mysql.sock
mysqlx_socket                                                 = /run/mysqlx.sock
pid_file                                                      = /run/mysql.pid
log_timestamps                                                = SYSTEM

# 兼容旧的认证方式
default_authentication_plugin                                 = mysql_native_password

default_storage_engine                                        = InnoDB
# Disable other storage engines
disabled_storage_engines                                      = "MyISAM,BLACKHOLE,FEDERATED,ARCHIVE,MEMORY"

# DATA STORAGE #
datadir                                                       = 
basedir                                                       = 

# CHARASET #
character_set_server                                          = utf8mb4
collation_server                                              = utf8mb4_unicode_ci

# BASIC #
userstat                                                      = 1

# MyISAM #
key_buffer_size                                               = 32M

# INTERACTIVE TIMEOUT #
net_read_timeout                                              = 30
net_write_timeout                                             = 600
lock_wait_timeout                                             = 60
wait_timeout                                                  = 7200
interactive_timeout                                           = 7200

# SAFETY #
explicit_defaults_for_timestamp                               = ON
secure_file_priv                                              = /tmp
slave_load_tmpdir                                             = /tmp
tmpdir                                                        = /tmp
skip_name_resolve
local_infile                                                  = 0
max_allowed_packet                                            = 1024M
max_connect_errors                                            = 1000000
lower_case_table_names                                        = 1
transaction_isolation                                         = READ-COMMITTED

# PERFORMANCE_SCHEMA #
performance_schema                                            = 1
performance_schema_instrument                                 = '%=on'
performance_schema_digests_size                               = 40000
performance_schema_max_table_instances                        = 40000
performance_schema_max_sql_text_length                        = 4096
performance_schema_max_digest_length                          = 4096
performance-schema-consumer-events-stages-current             = ON
performance-schema-consumer-events-stages-history             = ON
performance-schema-consumer-events-stages-history-long        = ON
performance-schema-consumer-events-statements-current         = ON
performance-schema-consumer-events-statements-history         = ON
performance-schema-consumer-events-statements-history-long    = ON
performance-schema-consumer-events-transactions-history-long  = ON

# BINARY LOGGING #
binlog_expire_logs_seconds                                    = 604800
binlog_format                                                 = ROW
binlog_row_image                                              = FULL
binlog_cache_size                                             = 512K
# binlog_rows_query_log_events                                = 1
sync_binlog                                                   = 1
log_bin                                                       = mysql-bin
log_slave_updates                                             = 1
binlog_order_commits                                          = ON
binlog_group_commit_sync_delay                                = 50
binlog_group_commit_sync_no_delay_count                       = 10
transaction_write_set_extraction                              = XXHASH64
binlog_transaction_dependency_tracking                        = WRITESET

# Replication Information Repositories #
master_info_repository                                        = TABLE
relay_log_info_repository                                     = TABLE

# GTID #
gtid_mode                                                     = ON
enforce_gtid_consistency                                      = ON

# REPLICATION #
read_only                                                     = 1
super_read_only                                               = 1
relay_log                                                     = /mysql_relay_bin
relay_log_index                                               = /mysql_relay_bin.index
skip_slave_start                                              = 1
replication_optimize_for_static_plugin_config                 = 1
replication_sender_observe_commit_only                        = 1

# Clone Plugin #
plugin_load_add                                               = mysql_clone.so

# PARALLEL #
slave_parallel_type                                           = LOGICAL_CLOCK
slave_parallel_workers                                        = 8
relay_log_recovery                                            = 1
slave_preserve_commit_order                                   = 1
slave_checkpoint_group                                        = 512
slave_checkpoint_period                                       = 300

# THREAD POOL  #
thread_handling                                               = one-thread-per-connection

# THREAD SHARED #
thread_stack                                                  = 256K
sort_buffer_size                                              = 1M
read_buffer_size                                              = 1M
join_buffer_size                                              = 1M
read_rnd_buffer_size                                          = 2M

# CACHES AND LIMITS #
tmp_table_size                                                = 32M      # 256M
max_heap_table_size                                           = 32M      # 256M
max_connections                                               = 10000
max_user_connections                                          = 1000
thread_cache_size                                             = 100
open_files_limit                                              = 65535
table_definition_cache                                        = 4096
table_open_cache                                              = 4096

# INNODB #
innodb_flush_method                                           = O_DIRECT
innodb_log_files_in_group                                     = 2
innodb_log_file_size                                          = 256M     # 1G
innodb_flush_log_at_trx_commit                                = 1
innodb_file_per_table                                         = 1
innodb_buffer_pool_size                                       = 
innodb_buffer_pool_instances                                  = 0
innodb_data_home_dir                                          = 
innodb_data_file_path                                         = ibdata1:128M:autoextend      # 1024M
innodb_temp_data_file_path                                    = ibtmp1:12M:autoextend:max:100G
innodb_lock_wait_timeout                                      = 50
innodb_rollback_on_timeout                                    = ON
innodb_old_blocks_pct                                         = 37
innodb_old_blocks_time                                        = 1000
innodb_numa_interleave                                        = 1
innodb_write_io_threads                                       = 8
innodb_read_io_threads                                        = 8
max_prepared_stmt_count                                       = 500000
innodb_read_io_threads                                        = 8
innodb_buffer_pool_load_at_startup                            = 1
innodb_buffer_pool_dump_at_shutdown                           = 1
innodb_print_all_deadlocks                                    = 1
innodb_status_output_locks                                    = 1
innodb_purge_threads                                          = 4
innodb_page_cleaners                                          = 4
innodb_max_dirty_pages_pct                                    = 50
innodb_max_undo_log_size                                      = 128M

# INNODB MONITOR #
innodb_monitor_enable                                         = all

# SETTING FOR SSD #
innodb_io_capacity                                            = 20000
innodb_io_capacity_max                                        = 50000
innodb_log_write_ahead_size                                   = 4096
innodb_flush_sync                                             = 0
innodb_flush_neighbors                                        = 0

# SLOW LOGGING #
log_output                                                    = file
slow-query-log-file                                           = /logs/slow.log
slow_query_log                                                = ON
long_query_time                                               = 0.1
log_slow_rate_limit                                           = 100
log_slow_rate_type                                            = query
log_slow_verbosity                                            = full
log_slow_admin_statements                                     = ON
log_slow_slave_statements                                     = ON
slow_query_log_always_write_time                              = 1
slow_query_log_use_global_control                             = all

# ERROR LOG #
log_error                                                     = /logs/mysqld.log
log_error_verbosity                                           = 2

# GENERAL LOG #
general_log_file                                              = /logs/general.log

# ADDITIONAL SETTINGS #
report_host                                                   = 
report_port                                                   = 123

[mysqld_safe]
log_error                                                     = /logs/mysqld.log
open_files_limit                                              = 65535

[mysqldump]
quick
max_allowed_packet                                            = 1024M

[mysql]
prompt                                                        = (\\u@\\h)[\\d]>\\_
