datadir="[[.ProxysqlDir ]]"

admin_variables=
{
        admin_credentials="admin:[[.AdminPassword ]];cluster:[[.ClusterPassword ]];dba:[[.DbaPassword ]]"
        cluster_username="cluster"
        ClusterPassword="[[.ClusterPassword ]]"
        cluster_mysql_query_rules_save_to_disk="true"
        cluster_mysql_servers_save_to_disk="true"
        cluster_mysql_users_save_to_disk="true"
        cluster_proxysql_servers_save_to_disk="true"
        cluster_mysql_query_rules_diffs_before_sync="3"
        cluster_mysql_servers_diffs_before_sync="3"
        cluster_mysql_users_diffs_before_sync="3"
        cluster_proxysql_servers_diffs_before_sync="3"
        stats_credentials="stats:[[.StatsPassword ]];check_alive:[[.ChickAlicePassword ]]"
        mysql_ifaces="0.0.0.0:[[.AdminPort ]]"
}

mysql_variables=
{
        threads=4
        max_connections=2048
        default_query_delay=0
        default_query_timeout=36000000
        have_compress=true
        poll_timeout=2000
        interfaces="0.0.0.0:1[[.AdminPort ]]"
        default_schema="information_schema"
        stacksize=1048576
        server_version="5.7.29"
        connect_timeout_server=3000
        monitor_username="proxysql"
        monitor_password="[[.MonitorPassword ]]"
        monitor_history=600000
        monitor_connect_interval=120000
        monitor_connect_timeout=10000
        monitor_ping_interval=10000
        monitor_ping_timeout=8000
        monitor_read_only_interval=10000
        monitor_read_only_timeout=8000
        ping_interval_server_msec=120000
        ping_timeout_server=500
        commands_stats=true
        sessions_sort=true
        connect_retries_on_failure=10
        default_charset="utf8"
        client_found_rows=false
        wait_timeout=7200000
        monitor_slave_lag_when_null=7200
        log_unhealthy_connections=false
}

proxysql_servers=
(
[[.ProxysqlServersJson]]
)

mysql_replication_hostgroups=
(
        {
                writer_hostgroup=[[.WriterHostgroup ]]
                reader_hostgroup=[[.ReaderHostgroup ]]
                comment="rw split"
        }
)

mysql_servers=
(
[[.ProxysqlMysqlServersJson ]]
)

mysql_users:
(
       {
                username="[[.ProxysqlMysqlUserUsername ]]"
                password="[[.ProxysqlMysqlUserPassword ]]"
                default_hostgroup=[[.WriterHostgroup ]]
                transaction_persistent=1
                max_connections=256
                active=1
       },
       {
                username="monitor_r"
                password="[[.MonitorRPassword ]]"
                default_hostgroup=[[.WriterHostgroup ]]
                transaction_persistent=1
                max_connections=32
                active=1
       },
       {
                username="monitor_rw"
                password="[[.MonitorRwPassword ]]"
                default_hostgroup=[[.WriterHostgroup ]]
                transaction_persistent=1
                max_connections=32
                active=1
       },
       {
                username="mha_user"
                password="[[.MhaPassword ]]"
                default_hostgroup=[[.WriterHostgroup ]]
                transaction_persistent=1
                max_connections=32
                active=1
       }
)

mysql_query_rules:
(
    {
        rule_id=1001
        flagIN=0
        flagOUT=10001
        username="[[.ProxysqlMysqlUserUsername ]]"
        active=1
        apply=0
    },
    {
        rule_id=10001
        flagIN=10001
        match_pattern="IS_FORWARD_SLAVE"
        destination_hostgroup=[[.ReaderHostgroup ]]
        active=1
        apply=1
    }
)
